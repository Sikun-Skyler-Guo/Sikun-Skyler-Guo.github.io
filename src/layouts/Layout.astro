---
import '../styles/global.css';
import { site, profile } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title ? `${title} | ${site.title}` : `${site.title} | Academic Homepage`;
const pageDescription = description ?? site.description;
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={pageDescription} />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#fafaf9" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body class="text-stone-900 antialiased">
    <div class="mx-auto flex min-h-screen max-w-6xl flex-col px-6 py-6 sm:px-8 lg:px-12 lg:py-8">
      <header class="mb-16 border-b border-[var(--border)] pb-8">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between">
          <div class="max-w-3xl">
            <a href="/" class="inline-block text-5xl font-semibold tracking-[-0.05em] text-stone-950 sm:text-6xl">{profile.name}</a>
            <p class="mt-3 text-lg font-medium tracking-tight text-stone-900 sm:text-xl">{profile.role}</p>
            <p class="mt-2 text-sm text-stone-600">{profile.affiliation} · Advisor: <a href={profile.advisorUrl} target="_blank" rel="noreferrer" class="underline decoration-stone-300 underline-offset-4 hover:decoration-[color:var(--accent)] hover:text-[color:var(--accent-strong)]">{profile.advisorName}</a> · {profile.location}</p>
            <p class="mt-4 max-w-3xl text-sm leading-7 text-stone-600">{profile.collaborationNote}</p>
            <div class="mt-5 flex flex-wrap gap-x-4 gap-y-2 text-sm text-stone-600">
              {profile.links.map((link) => (
                <a
                  href={link.href}
                  target={link.href.startsWith('http') ? '_blank' : undefined}
                  rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
                  class="underline decoration-stone-300 underline-offset-4 hover:decoration-[color:var(--accent)] hover:text-[color:var(--accent-strong)]"
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>

          <nav aria-label="Primary" class="flex flex-wrap items-center gap-x-6 gap-y-3 pt-2 text-sm text-stone-700 lg:justify-end">
            {site.nav.map((item) => {
              const active = pathname === item.href;
              return (
                <a
                  href={item.href}
                  aria-current={active ? 'page' : undefined}
                  class:list={[
                    'border-b pb-1 transition',
                    active
                      ? 'border-[color:var(--accent)] text-stone-950'
                      : 'border-transparent hover:border-stone-300 hover:text-[color:var(--accent-strong)]',
                  ]}
                >
                  {item.label}
                </a>
              );
            })}
          </nav>
        </div>
      </header>

      <main class="flex-1">
        <slot />
      </main>

      <footer class="mt-20 border-t border-[var(--border)] pt-6 text-sm text-stone-500">
        <div class="flex items-center justify-between">
          <p>{profile.name} · {profile.affiliation}</p>
        </div>
      </footer>
    </div>
  </body>
</html>
