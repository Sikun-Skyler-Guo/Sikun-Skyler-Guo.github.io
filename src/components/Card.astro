---
interface Props {
  title?: string;
  subtitle?: string;
  compact?: boolean;
}

const { title, subtitle, compact = false } = Astro.props;
---

<section class:list={[
  'card-surface rounded-[1.4rem] border border-[var(--border)] shadow-[0_10px_30px_-24px_rgba(41,37,36,0.28)]',
  compact ? 'p-5' : 'p-6 sm:p-7',
]}>
  {(title || subtitle) && (
    <header class="mb-4">
      {title && <h3 class="text-lg font-semibold text-stone-900">{title}</h3>}
      {subtitle && <p class="mt-1 text-sm text-stone-500">{subtitle}</p>}
    </header>
  )}
  <slot />
</section>
