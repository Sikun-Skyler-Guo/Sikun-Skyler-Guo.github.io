---
import type { Publication } from '../data/publications';

interface Props {
  paper: Publication;
  featured?: boolean;
}

const { paper, featured = false } = Astro.props;
const metaParts = paper.group === 'working'
  ? [paper.status, paper.tag, String(paper.year)]
  : [paper.tag, String(paper.year)];
---

<article class:list={[
  'card-surface border border-[var(--border)] bg-white rounded-[1.1rem] shadow-[0_12px_35px_-28px_rgba(15,23,42,0.35)]',
  featured ? 'p-6 sm:p-7' : 'p-5 sm:p-6',
]}>
  <div class:list={[featured && (paper.figureSrc || paper.figureLabel) ? 'grid gap-6 lg:grid-cols-[1.02fr_0.98fr] lg:items-start' : '']}>
    <div>
      <div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-[11px] uppercase tracking-[0.24em] text-stone-500">
        {metaParts.map((part, idx) => (
          <>
            {idx > 0 && <span aria-hidden="true">•</span>}
            <span>{part}</span>
          </>
        ))}
      </div>

      <h3 class="mt-3 text-[1.15rem] font-semibold tracking-tight text-stone-950 sm:text-[1.25rem]">
        {paper.links?.[0] ? (
          <a href={paper.links[0].href} target="_blank" rel="noreferrer" class="hover:text-[color:var(--accent-strong)]">
            {paper.title}
          </a>
        ) : (
          paper.title
        )}
      </h3>

      <p class="mt-2 text-sm text-stone-600">
        {paper.authors.map((author, idx) => (
          <>
            {idx > 0 && <span>{idx === paper.authors.length - 1 ? ' and ' : ', '}</span>}
            {author.me ? <strong>{author.name}</strong> : <span>{author.name}</span>}
          </>
        ))}
      </p>

      <p class="mt-2 text-sm font-medium text-stone-700">{paper.venue}</p>
      {paper.award && (
        <p class="mt-3 inline-flex w-fit items-center rounded-full border border-[color:var(--accent)]/20 bg-[color:var(--selection)] px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-[color:var(--accent-strong)]">
          {paper.award}
        </p>
      )}
      <p class="mt-4 text-sm leading-7 text-stone-700">{paper.summary}</p>

      {paper.links && paper.links.length > 0 && (
        <div class="mt-5 flex flex-wrap gap-x-4 gap-y-2 text-sm text-stone-600">
          {paper.links.map((link) => (
            <a href={link.href} target="_blank" rel="noreferrer" class="underline decoration-stone-300 underline-offset-4 hover:decoration-[color:var(--accent)] hover:text-[color:var(--accent-strong)]">
              {link.label}
            </a>
          ))}
        </div>
      )}
    </div>

    {featured && (paper.figureSrc || paper.figureLabel) && (
      <div class="rounded-[1rem] border border-dashed border-[var(--border)] bg-[var(--bg-muted)]/70 p-3 text-sm text-stone-500 lg:min-h-[220px]">
        {paper.figureSrc ? (
          <div class="h-full">
            <img src={paper.figureSrc} alt={paper.figureAlt ?? paper.figureLabel ?? paper.title} class="h-full w-full rounded-[0.7rem] border border-[var(--border)] bg-white object-contain" loading="lazy" />
          </div>
        ) : (
          <div>
            <p class="text-[11px] uppercase tracking-[0.24em] text-stone-400">Reserved figure slot</p>
            <p class="mt-3 leading-7">{paper.figureLabel}</p>
          </div>
        )}
      </div>
    )}
  </div>
</article>
