---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { cvData, profile } from '../data/site';
---

<Layout title="CV" description="CV snapshot for Sikun Guo.">
  <SectionHeading
    eyebrow="CV"
    title="Curriculum vitae snapshot"
    intro="A concise web version of the current resume, with a downloadable PDF for formal use."
  />

  <div class="mb-8 flex flex-wrap gap-3">
    <a href={profile.cvHref} data-goatcounter-click="click-cv-download" data-goatcounter-title="CV page PDF download" class="button-pill button-primary">Download PDF CV</a>
    <a href={`mailto:${profile.email}`} data-goatcounter-click="click-email" data-goatcounter-title="CV page email click" class="button-pill button-primary">Email Sikun</a>
  </div>

  <div class="space-y-8">
    <Card title="Contact">
      <div class="grid gap-4 text-sm text-stone-700 sm:grid-cols-2">
        <p><span class="font-medium text-stone-900">Name:</span> {profile.name}</p>
        <p><span class="font-medium text-stone-900">Email:</span> {profile.email}</p>
        <p><span class="font-medium text-stone-900">Role:</span> {profile.role}</p>
        <p><span class="font-medium text-stone-900">Location:</span> {profile.location}</p>
        <p class="sm:col-span-2"><span class="font-medium text-stone-900">Advisor:</span> <a href={profile.advisorUrl} target="_blank" rel="noreferrer" class="underline decoration-stone-300 underline-offset-4 hover:decoration-[color:var(--accent)] hover:text-[color:var(--accent-strong)]">{profile.advisorName}</a></p>
      </div>
    </Card>

    <Card title="Education">
      <div class="space-y-5">
        {cvData.education.map((item) => (
          <div class="border-b border-[var(--border)] pb-4 last:border-0">
            <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
              <h3 class="font-semibold text-stone-900">{item.degree}</h3>
              <p class="text-sm text-stone-500">{item.years}</p>
            </div>
            <p class="mt-1 text-sm font-medium text-stone-700">{item.institution}</p>
            <p class="mt-2 text-sm leading-7 text-stone-700">{item.details}</p>
          </div>
        ))}
      </div>
    </Card>

    <Card title="Research and industry experience">
      <div class="space-y-6">
        {cvData.experience.map((item) => (
          <div class="border-b border-[var(--border)] pb-5 last:border-0">
            <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
              <h3 class="font-semibold text-stone-900">{item.title}</h3>
              <p class="text-sm text-stone-500">{item.years}</p>
            </div>
            <p class="mt-1 text-sm font-medium text-stone-700">{item.org}</p>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm leading-7 text-stone-700">
              {item.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </Card>

    <section class="grid gap-6 md:grid-cols-2">
      <Card title="Awards and honors">
        <ul class="list-disc space-y-2 pl-5 text-sm leading-7 text-stone-700">
          {cvData.awards.map((award) => (
            <li>{award}</li>
          ))}
        </ul>
      </Card>
      <Card title="Service">
        <ul class="list-disc space-y-2 pl-5 text-sm leading-7 text-stone-700">
          {cvData.service.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </Card>
    </section>

    <section class="grid gap-6 md:grid-cols-2">
      <Card title="Programming languages">
        <p class="text-sm leading-7 text-stone-700">{cvData.skills.languages.join(' · ')}</p>
      </Card>
      <Card title="Tools and technologies">
        <p class="text-sm leading-7 text-stone-700">{cvData.skills.tools.join(' · ')}</p>
      </Card>
    </section>
  </div>
</Layout>
